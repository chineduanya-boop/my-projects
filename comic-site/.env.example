# PostgreSQL connection string from Supabase
# Found in: Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Cloudflare R2 credentials
# Found in: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name

# Public URL for your R2 bucket
# Enable public access in R2 bucket settings to get this URL
# e.g. https://pub-abc123.r2.dev
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

NODE_ENV=production
