# Twitter API v2 credentials
# Get these from https://developer.twitter.com/en/portal/dashboard
# Your app needs Read + Write permissions and OAuth 1.0a enabled

TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_token_secret_here

# Platform to post on: "twitter" or "facebook" (default: twitter)
PLATFORM=facebook

# ── Facebook Page credentials ─────────────────────────────────────────────────
# See setup guide in README — requires a Facebook Developer app
FB_PAGE_ID=your_facebook_page_id
FB_PAGE_ACCESS_TOKEN=your_page_access_token

# ── Facebook Groups (Playwright browser automation) ───────────────────────────
# No API tokens needed — uses a saved browser session instead.
# Setup:
#   1. npm install  (installs playwright)
#   2. npx playwright install chromium  (downloads the browser)
#   3. node fb-login.js  (opens a browser, you log in, session is saved)
#   4. node fb-scheduler.js  (runs the bot)
#
# Group IDs: open any group on Facebook, the number in the URL is the ID.
#   https://www.facebook.com/groups/146895504134058  →  146895504134058
FB_HEADLESS=true
FB_GROUP_IDS=123456789,987654321,555000111

# Optional: set to "true" to run in dry-run mode (logs actions without posting)
DRY_RUN=false

# ── AI tweet generation ───────────────────────────────────────────────────────

# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Engagement settings ───────────────────────────────────────────────────────

# Set to "false" to disable all engagement features (mentions, hashtags, follow-back, quote-tweets)
ENABLE_ENGAGEMENT=true

# Comma-separated hashtags to search and engage with
ENGAGE_HASHTAGS=manhwa,SoloLeveling,manga,TowerOfGod,ORV,anime

# Max posts to like+reply to per hashtag per run
ENGAGE_PER_HASHTAG=3
